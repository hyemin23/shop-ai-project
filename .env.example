# Claude Code Hooks — Slack 알림
SLACK_WEBHOOK_URL=

# Supabase
# 개발: shop-ai-dev 프로젝트 키
# 프로덕션: shop-ai 프로젝트 키
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API (서버 전용)
GEMINI_API_KEY=

# Kling AI API 서버 전용
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Toss Payments (Phase 4)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Vercel Cron 인증 (Vercel 배포 시 자동 주입됨)
CRON_SECRET=
